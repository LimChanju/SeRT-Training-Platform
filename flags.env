# Feature Flag 설정 파일
# 실행 전 `set -a; source flags.env; set +a` 또는 직접 환경 변수로 설정

# Flag 1: VR 모드 (true/false)
ENABLE_VR=false

# Flag 2: ERP 마커 로깅 (true/false), 롤아웃 비율 0-100
ENABLE_ERP_LOGGING=true
ERP_ROLLOUT_PCT=100

# Flag 3: 로봇 충돌 감지 (true/false)
ENABLE_ROBOT_COLLISION=true

# Flag 4: 레이캐스트 시각화 (true/false, 실험적)
ENABLE_RAYCAST=false

# Sticky proximity grab: 손이 큐브 근처에 오면 자동으로 붙는 개선 옵션
# 기본 목표는 pinch grab이므로 기본값은 OFF
POSE_PINCH_GRAB=false
STICKY_PROXIMITY_GRAB=false
STICKY_PROXIMITY_RADIUS=0.12

# VR visuals: RL용 사람 아바타를 scene object로 쓰고 XR 컨트롤러 모델은 숨김
XR_SHOW_CONTROLLERS=false
XR_HAND_PROXY_ENABLED=false
XR_HAND_SPHERE_ENABLED=false
XR_USE_OPENXR_HAND_JOINTS=false
XR_VISUALIZE_OPENXR_HAND_JOINTS=false
XR_DRAW_ARM_LINES=false

# Human avatar: VR HMD/손 pose를 scene 안의 사람 머리/팔로 표현
ENABLE_HUMAN_AVATAR=true
HUMAN_AVATAR_TASK=touch_green_cube
HUMAN_AVATAR_TASK_GREEN_INDEX=0
HUMAN_AVATAR_TOUCH_DIST=0.09
HUMAN_AVATAR_COLLISION_DIST=0.06

# Haptics / collision debug
DEBUG_HAPTICS_UDP=true
DEBUG_ARM_COLLISION=true
HAPTICS_ROBOT_COLLISION_LINK_FILTER=gripper
XR_ZERO_POSE_INVALID_DIST=0.03
XR_VIRTUAL_WORLD_POSE_FALLBACK=false
XR_STAGE_VISUAL_FALLBACK=false
XR_STAGE_VISUAL_SEARCH_INTERVAL_STEPS=120
XR_CONTROLLER_POSE_PRIORITY=palm,grip,aim,pinch,poke,default
ARM_ROBOT_COLLISION_MODE=controller
ARM_ROBOT_COLLISION_GEOMETRY=capsule
ARM_ROBOT_COLLISION_DIST=0.06
ARM_ROBOT_CAPSULE_RADIUS=0.09
ARM_ROBOT_FINGER_CAPSULE_RADIUS=0.035

# Gripper camera: 가림 여부 판단을 위한 wrist/gripper 카메라 prim 생성
ENABLE_GRIPPER_CAMERA=true
GRIPPER_CAMERA_PRIM_PATH=/World/GripperCamera
ENABLE_GRIPPER_CAMERA_VIEWPORT=true
GRIPPER_CAMERA_MOUNT_OFFSET=0.0,0.0,0.03
GRIPPER_CAMERA_FOCAL_LENGTH=28.0
ENABLE_GRIPPER_CAMERA_LIGHT=true
ENABLE_GRIPPER_CAMERA_RECORDING=false
GRIPPER_CAMERA_RECORD_DIR=./v2/gripper_camera_recording
GRIPPER_CAMERA_RECORD_RESOLUTION=640,480
GRIPPER_CAMERA_RECORD_INTERVAL_STEPS=5
GRIPPER_CAMERA_BLOCKING_RECORD_CAPTURE=false

# 특정 피험자에게만 VR 활성화 (쉼표 구분)
VR_SUBJECT_IDS=

# A/B 테스트 — variant 강제 지정 (A 또는 B, 비워두면 자동 할당)
AB_VARIANT_OVERRIDE=

# A/B 테스트 — Variant B 할당 비율 (0-100, 기본 50)
AB_VARIANT_B_PCT=50

BHAPTICS_NOTEBOOK_IP=172.20.10.3
BHAPTICS_UDP_PORT=5005
DEBUG_HAPTICS_UDP=true
